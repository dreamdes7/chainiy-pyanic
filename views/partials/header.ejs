<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title + ' — ' : '' %>Чайный пьяница</title>
  <meta name="description" content="Чайный пьяница — лавка редкого листового чая. Китай, Япония, Индия, Тайвань.">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Bitter:ital,wght@0,400;0,500;0,600;0,700;0,800;0,900;1,500;1,700&family=Golos+Text:wght@400;500;600;700;900&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<div class="grain"></div>
<div class="vignette"></div>

<div class="ticker">
  <div class="ticker-track">
    <span><i>✦</i> Свежий сбор 2024</span>
    <span><i>✦</i> Бесплатная доставка от 3000 ₽</span>
    <span><i>✦</i> Только цельный лист — без ароматизаторов</span>
    <span><i>✦</i> Китай · Япония · Индия · Тайвань</span>
    <span><i>✦</i> Свежий сбор 2024</span>
    <span><i>✦</i> Бесплатная доставка от 3000 ₽</span>
    <span><i>✦</i> Только цельный лист — без ароматизаторов</span>
    <span><i>✦</i> Китай · Япония · Индия · Тайвань</span>
  </div>
</div>

<header class="header">
  <div class="container header-inner">
    <a class="logo" href="/">Чайный&nbsp;<b>пьяница</b><span class="dot"></span></a>
    <button class="nav-toggle" aria-label="Меню">☰</button>
    <nav class="nav">
      <a href="/">Главная</a>
      <a href="/catalog">Каталог</a>
      <% if (user) { %><a href="/orders">Заказы</a><% } %>
      <% if (user && (user.role === 'admin' || user.role === 'manager')) { %><a href="/admin">Панель</a><% } %>
    </nav>
    <div class="header-right">
      <% if (user) { %>
        <a href="/orders" class="header-user">◆ <%= user.name %></a>
        <a href="/cart" class="cart-link">Корзина</a>
        <form action="/auth/logout" method="POST" style="display:inline">
          <button type="submit" class="btn-logout">Выйти</button>
        </form>
      <% } else { %>
        <a href="/auth/login" class="header-user">Войти</a>
        <a href="/cart" class="cart-link">Корзина</a>
      <% } %>
    </div>
  </div>
</header>
