<%- include('../partials/header', { title: 'Регистрация' }) %>

<div class="container page">
  <div class="auth">
    <div class="auth-brand">
      <div class="mark">Чайный пьяница</div>
      <h1>Создать аккаунт</h1>
      <p>Добро пожаловать в лавку</p>
    </div>

    <% if (error) { %><div class="form-err"><%= error %></div><% } %>

    <form action="/auth/register" method="POST">
      <div class="field">
        <label>Имя</label>
        <input type="text" name="name" placeholder="Иван Иванов" required autofocus>
      </div>
      <div class="field">
        <label>Email</label>
        <input type="email" name="email" placeholder="your@email.com" required>
      </div>
      <div class="field">
        <label>Пароль</label>
        <input type="password" name="password" placeholder="Минимум 6 символов" minlength="6" required>
      </div>
      <button type="submit" class="btn btn-primary btn-block">Зарегистрироваться</button>
    </form>

    <div class="form-foot">Уже есть аккаунт? <a href="/auth/login">Войти</a></div>
  </div>
</div>

<%- include('../partials/footer') %>
