<%- include('../partials/header', { title: 'Мои заказы' }) %>

<div class="container page">
  <div class="page-head"><h1>Мои заказы</h1></div>

  <% if (orders.length === 0) { %>
  <div class="empty">
    <span class="ic">📦</span>
    <h2>Заказов пока нет</h2>
    <p>Самое время это исправить</p>
    <a href="/catalog" class="btn btn-primary">В каталог</a>
  </div>
  <% } else { %>
  <% const labels = {pending:'Ожидает',confirmed:'Подтверждён',shipped:'Отправлен',delivered:'Доставлен',cancelled:'Отменён'}; %>
  <div class="orders">
    <% orders.forEach(order => { %>
    <div class="order-card">
      <div class="order-id">#<%= order.id %></div>
      <div class="order-meta">
        <strong><%= new Date(order.created_at).toLocaleDateString('ru', {day:'numeric',month:'long',year:'numeric'}) %></strong>
        <% if (order.address) { %><span>📍 <%= order.address %></span><% } %>
      </div>
      <span class="badge badge-<%= order.status %>"><%= labels[order.status] || order.status %></span>
      <div style="text-align:right">
        <div class="order-total"><%= Number(order.total).toLocaleString('ru') %> ₽</div>
        <a href="/orders/<%= order.id %>" class="btn btn-ghost btn-sm" style="margin-top:.5rem">Подробнее</a>
      </div>
    </div>
    <% }) %>
  </div>
  <% } %>
</div>

<%- include('../partials/footer') %>
