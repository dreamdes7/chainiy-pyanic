<%- include('../../partials/header', { title: 'Панель' }) %>

<div class="container page">
  <div class="admin">
    <%- include('../../partials/admin-nav', { active: 'dashboard', user }) %>

    <div class="admin-content">
      <h2>Обзор</h2>

      <div class="stats">
        <div class="stat"><div class="v"><%= stats.total_orders %></div><div class="l">Всего заказов</div></div>
        <div class="stat gold"><div class="v"><%= stats.pending %></div><div class="l">Ожидают обработки</div></div>
      </div>

      <div class="panel">
        <h3>Последние заказы</h3>
        <% if (recentOrders.length === 0) { %>
        <p style="color:var(--ink-soft);font-family:var(--mono);font-size:.8rem">Заказов пока нет</p>
        <% } else { %>
        <% const labels = {pending:'Ожидает',confirmed:'Подтверждён',shipped:'Отправлен',delivered:'Доставлен',cancelled:'Отменён'}; %>
        <table class="tbl">
          <thead><tr><th>#</th><th>Покупатель</th><th>Сумма</th><th>Статус</th><th>Дата</th><th>Действие</th></tr></thead>
          <tbody>
            <% recentOrders.forEach(o => { %>
            <tr>
              <td><strong>#<%= o.id %></strong></td>
              <td><%= o.user_name %></td>
              <td style="font-weight:700"><%= Number(o.total).toLocaleString('ru') %> ₽</td>
              <td><span class="badge badge-<%= o.status %>"><%= labels[o.status] || o.status %></span></td>
              <td style="color:var(--ink-soft);font-size:.82rem"><%= new Date(o.created_at).toLocaleDateString('ru') %></td>
              <td>
                <form action="/admin/orders/<%= o.id %>/status" method="POST" class="inline">
                  <select name="status">
                    <% ['pending','confirmed','shipped','delivered','cancelled'].forEach(s => { %>
                    <option value="<%= s %>" <%= o.status === s ? 'selected' : '' %>><%= labels[s] %></option>
                    <% }) %>
                  </select>
                  <button type="submit" class="btn btn-sm">OK</button>
                </form>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
        <% } %>
      </div>
    </div>
  </div>
</div>

<%- include('../../partials/footer') %>
