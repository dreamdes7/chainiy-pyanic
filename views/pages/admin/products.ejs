<%- include('../../partials/header', { title: 'Товары — Панель' }) %>

<div class="container page">
  <div class="admin">
    <%- include('../../partials/admin-nav', { active: 'products', user }) %>

    <div class="admin-content">
      <h2>Товары</h2>

      <div class="panel">
        <h3>Добавить товар</h3>
        <form action="/admin/products" method="POST">
          <div class="frow">
            <div class="field"><label>Название</label><input type="text" name="name" placeholder="Дарджилинг FTGFOP" required></div>
            <div class="field"><label>Slug (URL)</label><input type="text" name="slug" placeholder="darjeeling-ftgfop" required></div>
          </div>
          <div class="field"><label>Описание</label><textarea name="description" placeholder="Описание чая…"></textarea></div>
          <div class="frow">
            <div class="field"><label>Цена (₽)</label><input type="number" name="price" min="0" step="0.01" placeholder="590" required></div>
            <div class="field"><label>Остаток (шт.)</label><input type="number" name="stock" min="0" placeholder="100" required></div>
          </div>
          <div class="frow">
            <div class="field">
              <label>Категория</label>
              <select name="category_id">
                <option value="">— Без категории —</option>
                <% categories.forEach(c => { %><option value="<%= c.id %>"><%= c.name %></option><% }) %>
              </select>
            </div>
            <div class="field"><label>URL изображения</label><input type="text" name="image_url" placeholder="/images/products/slug.jpg"></div>
          </div>
          <button type="submit" class="btn btn-primary">Добавить товар</button>
        </form>
      </div>

      <div class="panel">
        <h3>Все товары — <%= products.length %></h3>
        <% if (products.length === 0) { %>
        <p style="color:var(--ink-soft);font-family:var(--mono);font-size:.8rem">Товаров пока нет</p>
        <% } else { %>
        <table class="tbl">
          <thead><tr><th>Название</th><th>Категория</th><th>Цена</th><th>Остаток</th><th></th></tr></thead>
          <tbody>
            <% products.forEach(p => { %>
            <tr>
              <td><a href="/product/<%= p.slug %>" target="_blank" style="font-weight:600"><%= p.name %></a></td>
              <td style="color:var(--ink-soft)"><%= p.category_name || '—' %></td>
              <td style="font-weight:700"><%= Number(p.price).toLocaleString('ru') %> ₽</td>
              <td style="color:<%= p.stock > 0 ? 'var(--green)' : 'var(--stamp)' %>;font-weight:600"><%= p.stock %> шт.</td>
              <td>
                <form action="/admin/products/<%= p.id %>/delete" method="POST" class="inline" onsubmit="return confirm('Удалить товар?')">
                  <button type="submit" class="btn btn-danger btn-sm">Удалить</button>
                </form>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
        <% } %>
      </div>
    </div>
  </div>
</div>

<%- include('../../partials/footer') %>
