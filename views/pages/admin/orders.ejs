<%- include('../../partials/header', { title: 'Заказы — Панель' }) %>

<div class="container page">
  <div class="admin">
    <%- include('../../partials/admin-nav', { active: 'orders', user }) %>

    <div class="admin-content">
      <h2>Заказы — <%= orders.length %></h2>

      <div class="panel">
        <% if (orders.length === 0) { %>
        <p style="color:var(--ink-soft);font-family:var(--mono);font-size:.8rem">Заказов пока нет</p>
        <% } else { %>
        <% const labels = {pending:'Ожидает',confirmed:'Подтверждён',shipped:'Отправлен',delivered:'Доставлен',cancelled:'Отменён'}; %>
        <table class="tbl">
          <thead><tr><th>#</th><th>Покупатель</th><th>Email</th><th>Адрес</th><th>Сумма</th><th>Статус</th><th>Дата</th><th>Действие</th></tr></thead>
          <tbody>
            <% orders.forEach(o => { %>
            <tr>
              <td><strong>#<%= o.id %></strong></td>
              <td><%= o.user_name %></td>
              <td style="font-size:.8rem;color:var(--ink-soft)"><%= o.email %></td>
              <td style="font-size:.8rem;max-width:150px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap"><%= o.address || '—' %></td>
              <td style="font-weight:700"><%= Number(o.total).toLocaleString('ru') %> ₽</td>
              <td><span class="badge badge-<%= o.status %>"><%= labels[o.status] || o.status %></span></td>
              <td style="font-size:.8rem;color:var(--ink-soft)"><%= new Date(o.created_at).toLocaleDateString('ru') %></td>
              <td>
                <form action="/admin/orders/<%= o.id %>/status" method="POST" class="inline">
                  <select name="status">
                    <% ['pending','confirmed','shipped','delivered','cancelled'].forEach(s => { %>
                    <option value="<%= s %>" <%= o.status === s ? 'selected' : '' %>><%= labels[s] %></option>
                    <% }) %>
                  </select>
                  <button type="submit" class="btn btn-sm">OK</button>
                </form>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
        <% } %>
      </div>
    </div>
  </div>
</div>

<%- include('../../partials/footer') %>
