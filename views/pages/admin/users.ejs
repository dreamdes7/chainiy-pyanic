<%- include('../../partials/header', { title: 'Пользователи — Панель' }) %>

<div class="container page">
  <div class="admin">
    <%- include('../../partials/admin-nav', { active: 'users', user }) %>

    <div class="admin-content">
      <h2>Пользователи — <%= users.length %></h2>

      <div class="panel">
        <table class="tbl">
          <thead><tr><th>#</th><th>Имя</th><th>Email</th><th>Роль</th><th>Регистрация</th><th>Изменить роль</th></tr></thead>
          <tbody>
            <% users.forEach(u => { %>
            <tr>
              <td><%= u.id %></td>
              <td style="font-weight:600"><%= u.name %></td>
              <td style="font-size:.84rem;color:var(--ink-soft)"><%= u.email %></td>
              <td><span class="badge badge-<%= u.role==='admin' ? 'cancelled' : u.role==='manager' ? 'confirmed' : 'delivered' %>"><%= u.role %></span></td>
              <td style="font-size:.8rem;color:var(--ink-soft)"><%= new Date(u.created_at).toLocaleDateString('ru') %></td>
              <td>
                <% if (u.id !== user.id) { %>
                <form action="/admin/users/<%= u.id %>/role" method="POST" class="inline">
                  <select name="role">
                    <option value="customer" <%= u.role==='customer' ? 'selected' : '' %>>customer</option>
                    <option value="manager" <%= u.role==='manager' ? 'selected' : '' %>>manager</option>
                    <option value="admin" <%= u.role==='admin' ? 'selected' : '' %>>admin</option>
                  </select>
                  <button type="submit" class="btn btn-sm">OK</button>
                </form>
                <% } else { %>
                <span style="font-family:var(--mono);font-size:.72rem;color:var(--ink-soft)">это вы</span>
                <% } %>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>

<%- include('../../partials/footer') %>
