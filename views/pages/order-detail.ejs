<%- include('../partials/header', { title: 'Заказ #' + order.id }) %>

<div class="container page">
  <div class="breadcrumb">
    <a href="/">Главная</a>
    <span><a href="/orders">Мои заказы</a></span>
    <span>Заказ #<%= order.id %></span>
  </div>

  <div style="display:flex;align-items:center;gap:1rem;margin-bottom:2rem;flex-wrap:wrap">
    <h1 style="font-size:1.8rem;font-weight:800">Заказ #<%= order.id %></h1>
    <% const labels = {pending:'Ожидает',confirmed:'Подтверждён',shipped:'Отправлен',delivered:'Доставлен',cancelled:'Отменён'}; %>
    <span class="badge badge-<%= order.status %>" style="font-size:.88rem;padding:.4rem 1rem"><%= labels[order.status] || order.status %></span>
  </div>

  <div style="display:grid;grid-template-columns:1fr 320px;gap:2rem;align-items:start">
    <div>
      <div class="admin-card">
        <h3>Состав заказа</h3>
        <table class="data-table">
          <thead>
            <tr><th>Товар</th><th>Кол-во</th><th>Цена</th><th>Сумма</th></tr>
          </thead>
          <tbody>
            <% items.forEach(item => { %>
            <tr>
              <td><%= item.name %></td>
              <td><%= item.quantity %> шт.</td>
              <td><%= Number(item.price).toLocaleString('ru') %> ₽</td>
              <td style="font-weight:700"><%= (item.price * item.quantity).toLocaleString('ru') %> ₽</td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>

    <div class="admin-card" style="position:sticky;top:80px">
      <h3>Детали заказа</h3>
      <div style="display:flex;flex-direction:column;gap:.9rem">
        <div>
          <div style="font-size:.82rem;color:var(--text-muted)">Дата оформления</div>
          <div style="font-weight:600"><%= new Date(order.created_at).toLocaleString('ru') %></div>
        </div>
        <% if (order.address) { %>
        <div>
          <div style="font-size:.82rem;color:var(--text-muted)">Адрес доставки</div>
          <div style="font-weight:600"><%= order.address %></div>
        </div>
        <% } %>
        <div style="padding-top:.9rem;border-top:2px solid var(--green-light)">
          <div style="font-size:.9rem;color:var(--text-muted)">Итого</div>
          <div style="font-size:1.8rem;font-weight:800;color:var(--green-dark)"><%= Number(order.total).toLocaleString('ru') %> ₽</div>
        </div>
      </div>
    </div>
  </div>

  <div style="margin-top:2rem">
    <a href="/orders" class="btn btn-secondary">← Все заказы</a>
  </div>
</div>

<%- include('../partials/footer') %>
