<%- include('../partials/header', { title: 'Заказ #' + order.id }) %>

<div class="container page">
  <div class="crumbs">
    <a href="/">Главная</a><span class="sep">/</span>
    <a href="/orders">Заказы</a><span class="sep">/</span>
    <span>#<%= order.id %></span>
  </div>

  <% const labels = {pending:'Ожидает',confirmed:'Подтверждён',shipped:'Отправлен',delivered:'Доставлен',cancelled:'Отменён'}; %>
  <div class="page-head" style="display:flex;align-items:baseline;gap:1rem;flex-wrap:wrap">
    <h1>Заказ #<%= order.id %></h1>
    <span class="badge badge-<%= order.status %>"><%= labels[order.status] || order.status %></span>
  </div>

  <div class="cart">
    <div class="panel">
      <h3>Состав заказа</h3>
      <table class="tbl">
        <thead><tr><th>Товар</th><th>Кол-во</th><th>Цена</th><th>Сумма</th></tr></thead>
        <tbody>
          <% items.forEach(item => { %>
          <tr>
            <td><%= item.name %></td>
            <td><%= item.quantity %> шт.</td>
            <td><%= Number(item.price).toLocaleString('ru') %> ₽</td>
            <td style="font-weight:700"><%= (item.price * item.quantity).toLocaleString('ru') %> ₽</td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>

    <div class="summary">
      <h3>Детали</h3>
      <div class="sum-row"><span>Дата</span><span><%= new Date(order.created_at).toLocaleDateString('ru') %></span></div>
      <% if (order.address) { %>
      <div class="sum-row" style="flex-direction:column;gap:.2rem"><span>Адрес</span><span style="color:var(--ink)"><%= order.address %></span></div>
      <% } %>
      <div class="sum-total"><span class="l">Итого</span><span class="v"><%= Number(order.total).toLocaleString('ru') %> ₽</span></div>
      <a href="/orders" class="btn btn-ghost btn-block" style="margin-top:1.4rem">← Все заказы</a>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
