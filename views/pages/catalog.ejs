<%- include('../partials/header', { title: 'Каталог' }) %>

<div class="container page">
  <div class="crumbs">
    <a href="/">Главная</a><span class="sep">/</span><span>Каталог</span>
  </div>

  <div class="page-head">
    <h1>Каталог</h1>
    <p>Выберите свой лист</p>
  </div>

  <div class="shop">
    <aside class="aside">
      <div class="aside-block">
        <h3>Поиск</h3>
        <form action="/catalog" method="GET" class="search">
          <% if (query.category) { %><input type="hidden" name="category" value="<%= query.category %>"><% } %>
          <input type="text" name="search" placeholder="Название…" value="<%= query.search || '' %>">
          <button type="submit" class="btn btn-icon">🔍</button>
        </form>
      </div>
      <div class="aside-block">
        <h3>Категории</h3>
        <ul class="filters">
          <li><a href="/catalog<%= query.search ? '?search='+query.search : '' %>" class="<%= !query.category ? 'active' : '' %>">Все чаи</a></li>
          <% categories.forEach(c => { %>
          <li><a href="/catalog?category=<%= c.slug %><%= query.search ? '&search='+query.search : '' %>" class="<%= query.category === c.slug ? 'active' : '' %>"><%= c.name %></a></li>
          <% }) %>
        </ul>
      </div>
    </aside>

    <div>
      <% if (products.length === 0) { %>
      <div class="empty">
        <span class="ic">🔍</span>
        <h2>Ничего не найдено</h2>
        <p>Попробуйте изменить фильтры</p>
        <a href="/catalog" class="btn btn-primary">Сбросить</a>
      </div>
      <% } else { %>
      <div class="shop-count">Найдено <b><%= products.length %></b> позиций</div>
      <div class="grid">
        <% products.forEach(p => { %>
          <%- include('../partials/product-card', { p }) %>
        <% }) %>
      </div>
      <% } %>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
