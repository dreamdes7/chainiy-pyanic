<%- include('../partials/header', { title: 'Каталог' }) %>

<div class="container page">
  <div class="breadcrumb">
    <a href="/">Главная</a>
    <span class="sep">/</span>
    <span>Каталог</span>
  </div>

  <div class="page-head">
    <h1>Каталог чая</h1>
    <p>Выберите идеальный сорт из нашей коллекции</p>
  </div>

  <div class="catalog-layout">
    <aside class="sidebar">
      <div class="block">
        <h3>Поиск</h3>
        <form action="/catalog" method="GET" class="search-form">
          <% if (query.category) { %><input type="hidden" name="category" value="<%= query.category %>"><% } %>
          <input type="text" name="search" placeholder="Название чая…" value="<%= query.search || '' %>">
          <button type="submit" class="btn btn-primary btn-icon">🔍</button>
        </form>
      </div>

      <div class="block">
        <h3>Категории</h3>
        <ul class="filter-list">
          <li><a href="/catalog<%= query.search ? '?search='+query.search : '' %>" class="<%= !query.category ? 'active' : '' %>">Все чаи</a></li>
          <% categories.forEach(c => { %>
          <li>
            <a href="/catalog?category=<%= c.slug %><%= query.search ? '&search='+query.search : '' %>"
               class="<%= query.category === c.slug ? 'active' : '' %>">
              <%= c.name %>
            </a>
          </li>
          <% }) %>
        </ul>
      </div>
    </aside>

    <div>
      <% if (products.length === 0) { %>
      <div class="empty-state">
        <span class="icon">🔍</span>
        <h2>Ничего не найдено</h2>
        <p>Попробуйте изменить фильтры или поисковый запрос</p>
        <a href="/catalog" class="btn btn-primary">Сбросить фильтры</a>
      </div>
      <% } else { %>
      <div class="catalog-count">Найдено: <strong><%= products.length %></strong> товаров</div>
      <div class="products-grid">
        <% products.forEach(p => { %>
        <%- include('../partials/product-card', { p }) %>
        <% }) %>
      </div>
      <% } %>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
